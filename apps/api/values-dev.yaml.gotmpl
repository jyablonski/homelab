# Dev-only overrides, active for `helmfile -e dev` (used by Tilt); renders to
# {} otherwise. uvicorn --reload picks up files live-synced into /app/src.
{{- if eq .Environment.Name "dev" }}
args:
  - uvicorn
  - main:app
  - --host
  - 0.0.0.0
  - --port
  - "8000"
  - --proxy-headers
  - --reload
  - --reload-dir
  - /app/src
{{- else }}
{}
{{- end }}
